          "class_name": "SequenceExportWorkflow",
        },
      ],
      // Realtime broker DO — redeclared because durable_objects + migrations
      // are non-inheritable across env blocks. Keep the `v1` migration tag in
      // sync with the top-level block. No container here: e2e stays hermetic
      // (Docker-free); without the binding the SequenceExportWorkflow fails the
      // export cleanly (marks the row `failed`) rather than rendering.
      "durable_objects": {
        "bindings": [
          {
            "name": "REALTIME",
            "class_name": "RealtimeChannel",
          },
        ],
      },
      "migrations": [
        {
          "tag": "v1",
          "new_sqlite_classes": ["RealtimeChannel"],
        },
      ],
      // Explicit empty array opts out of inheritance and silences wrangler's
      // "tail_consumers not on env.test" warning. We don't want e2e runs
      // forwarding LogTape JSON into the prod PostHog log pipeline.
      "tail_consumers": [],
    },
  },
}

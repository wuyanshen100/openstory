# =============================================================================
# Environment Configuration
# `bun dev` auto-generates a working .env.local on first run — you only need
# this file as a reference for optional services. `bun setup` adds AI keys.
# =============================================================================

# =============================================================================
# REQUIRED - auto-generated by `bun dev` if missing
# =============================================================================

# App Configuration (contact/privacy emails shown on marketing pages are
# derived from VITE_APP_URL's domain — hello@<domain> / privacy@<domain>)
VITE_APP_URL=http://localhost:3000
VITE_APP_NAME=OpenStory

# Auth (auto-generated)
BETTER_AUTH_SECRET=

# Database - Cloudflare D1
# No local config needed: `bun dev` runs the worker (Workerd via the
# @cloudflare/vite-plugin), which serves a local Miniflare-backed D1.
# Production D1 is configured in wrangler.jsonc.

# =============================================================================
# WORKFLOWS - Async AI generation runs on Cloudflare Workflows
# No local config needed: `bun dev` runs the worker (Workerd via the
# @cloudflare/vite-plugin), which supplies the workflow bindings.
# =============================================================================

# =============================================================================
# AI SERVICES - Needed for generation features
# =============================================================================

# FAL_KEY=           # https://fal.ai - image, video & audio; also covers LLM calls via fal's OpenRouter endpoint
# OPENROUTER_KEY=    # https://openrouter.ai - LLM access for script analysis (optional with FAL_KEY set)

# =============================================================================
# STORAGE - Cloudflare R2 (native bindings in wrangler.jsonc)
#
# Local dev needs NONE of these: storage uses the local Miniflare R2 binding
# and the worker's /r2/$ route serves reads when R2_PUBLIC_STORAGE_DOMAIN is
# unset. To opt into remote R2, set R2_PUBLIC_STORAGE_DOMAIN here and
# "remote": true on the binding in wrangler.jsonc.
# =============================================================================

# R2_PUBLIC_STORAGE_DOMAIN=storage.example.com
# R2_PUBLIC_ASSETS_BUCKET=my-app-assets              # Shared across all environments
# VITE_R2_PUBLIC_ASSETS_DOMAIN=assets.example.com     # Same for staging and production

# S3 API credentials — only needed by the content upload scripts
# (scripts/upload-style-previews-to-r2.ts, upload-style-sample-videos-to-r2.ts).
# The app itself never uses them.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=my-app-storage

# Realtime progress updates run on a Cloudflare Durable Object (`REALTIME`
# binding in wrangler.jsonc) — no external Redis/Upstash config required.

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# Google OAuth - social sign-in (falls back to email OTP if not set)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email - transactional emails via Cloudflare Email Service (the SEND_EMAIL
# binding in wrangler.jsonc). Local dev simulates sends — email content is
# logged to the console instead of delivered, so no config is needed.
# In production EMAIL_FROM must be an address on a domain onboarded in
# Cloudflare Email Service (dashboard adds SPF/DKIM/DMARC automatically).
# Dev: leaving EMAIL_FROM unset enables the zero-friction fixed-OTP sign-in
# (submitting an email on /login signs you straight in). Setting it switches
# dev back to the real email-OTP flow with random codes — copy the code from
# the simulated-email console log, or flip the SEND_EMAIL binding to
# `"remote": true` for real delivery.
# EMAIL_FROM=noreply@example.com

# Billing - Stripe payments (optional, billing/credits always active)
# STRIPE_SECRET_KEY=               # Enables Stripe checkout and auto-top-up
# STRIPE_WEBHOOK_SECRET=

# BYOK API Key Encryption (required if users bring their own AI keys)
# Auto-generated by `bun dev` in .env.local
# API_KEY_ENCRYPTION_KEY=

# Observability - LLM tracing via Langfuse (optional, gracefully degrades)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PROMPTS_ENABLED=false  # Set to "true" to fetch prompts from Langfuse API

# Analytics (PostHog) - product analytics, error tracking & LLM observability (optional)
# VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=   # https://us.posthog.com/settings/project
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# System admin emails (comma-separated, for gift code management)
# ADMIN_EMAILS=admin@example.com

# Server-side video export (#968): route the export workflow to the local
# `bun dev:bunny` service instead of the production Cloudflare Container.
# `bun dev:all` sets this automatically (full local export loop, zero config).
# Only set it here if you run `bun dev` + `bun dev:bunny` in separate terminals
# instead. Leave unset for normal dev (export then reports "production only").
# VIDEO_EXPORT_DEV_URL=http://localhost:8080

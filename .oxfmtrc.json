{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": true,
  "trailingComma": "es5",
  "singleQuote": true,
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "ignorePatterns": [
    "public/mockServiceWorker.js",
    "*.gen.ts",
    ".vscode/**",
    "bun.lockb",
    "gen.types.ts",
    "routeTree.gen.ts",
    "worker-configuration.d.ts",
    ".vscode/settings.json"
  ]
}

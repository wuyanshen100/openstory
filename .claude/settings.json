{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Read",
      "Bash(bun lint:*)",
      "Bash(bun lint)",
      "Bash(bun lint:fix)",
      "Bash(bun format:*)",
      "Bash(bun format)",
      "Bash(bun typecheck)",
      "Bash(bun format:check)",
      "Bash(bunx oxlint:*)",
      "Bash(bunx oxfmt:*)",
      "Bash(bun tsgo:*)",
      "Bash(bun test:*)",
      "Bash(bun test --watch)",
      "Bash(bun test --coverage)",
      "Bash(bun test --watch --coverage)",
      "Bash(bun run lint:*)",
      "Bash(bun run lint)",
      "Bash(bun run lint:fix)",
      "Bash(bun format:*)",
      "Bash(bun run format)",
      "Bash(bun run typecheck)",
      "Bash(bun run format:check)",
      "Bash(bun run oxlint:*)",
      "Bash(bun run oxfmt:*)",
      "Bash(bun run tsgo:*)",
      "Bash(bun run test:*)",
      "Bash(bun run test --watch)",
      "Bash(bun run build:*)",
      "Bash(bun run build)",
      "Bash(gh pr view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue comment:*)",
      "Bash(rg:*)",
      "Bash(git status)",
      "Bash(cat:*)",
      "Bash(bun storybook:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(git mv:*)",
      "Bash(bun cf:typegen:all:*)",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__context7__get-library-docs",
      "mcp__context7__resolve-library-id",
      "mcp__chrome-devtools__list_pages",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(bun install:*)",
      "Skill(agent-browser)",
      "Bash(curl:*)",
      "Bash(git log:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:blog.cloudflare.com)",
      "Bash(ls:*)",
      "WebFetch(domain:developers.cloudflare.com)",
      "Bash(git mv:*)",
      "Bash(git ls-tree:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "WebFetch(domain:upstash.com)",
      "Bash(git add:*)",
      "WebFetch(domain:fal.ai)",
      "mcp__claude_ai_Fal__SearchFal",
      "Bash(npx @tanstack/cli *)",
      "Bash(npx --yes @tanstack/cli doc *)"
    ],
    "deny": ["Bash(bun tsc:*)"],
    "ask": [
      "Bash(bun dev)",
      "Bash(bun db:migrate:*)",
      "Bash(bun db:migrate)",
      "Bash(bun db:push:*)",
      "Bash(bun db:push)",
      "Bash(bun db:generate:*)",
      "Bash(bun db:generate)",
      "Bash(drizzle-kit migrate:*)",
      "Bash(drizzle-kit push:*)",
      "Bash(drizzle-kit generate:*)",
      "Bash(bun --bun drizzle-kit:*)",
      "Bash(bunx drizzle-kit:*)",
      "Bash(wrangler d1 execute:*)",
      "Bash(bunx wrangler d1 execute:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["shadcn"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-ripgrep.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-lint.sh"
          }
        ]
      }
    ]
  }
}

  },
  "devDependencies": {
    "@cf-wasm/photon": "^0.3.5",
    "@chromatic-com/storybook": "^5.2.1",
    "@clack/prompts": "^1.4.0",
    "@cloudflare/vite-plugin": "^1.37.0",
    "@copilotkit/aimock": "^1.35.0",
    "@faker-js/faker": "^10.4.0",
    "@logtape/pretty": "^2.1.1",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/react-ai-devtools": "^0.2.48",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260514.1",
    "@vitejs/plugin-react": "^6.0.2",
    "chalk": "^5.6.2",
    "json5": "^2.2.3",
    "knip": "^6.13.1",
    "lefthook": "^2.1.6",
    "msw": "^2.14.6",
    "msw-storybook-addon": "^2.0.7",
    "oxfmt": "0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "0.22.1",
    "playwright": "^1.60.0",
    "shadcn": "^4.7.0",
    "storybook": "^10.4.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.0.0",
    "wrangler": "^4.91.0"
  },
  "overrides": {
    "qs": "6.15.2",
    "ws": "^8.20.1"
  },
  "engines": {
    "bun": ">=1.3.0 < 2",
    "node": ">=24 < 25"
  },
  "cloudflare": {
    "bindings": {
      "BETTER_AUTH_SECRET": {
        "description": "Signs session cookies. Generate a random string with `openssl rand -hex 32`."
      },
      "API_KEY_ENCRYPTION_KEY": {
        "description": "Encrypts AI keys that teams add in-app (bring-your-own-key). Generate with `openssl rand -hex 32`."
      },
      "EMAIL_FROM": {
        "description": "Sender address for sign-in code emails, e.g. `noreply@yourdomain.com`. Required for sign-in: authentication is passwordless (emailed one-time codes), so without it nobody can create an account on this deployment. The domain must be onboarded in [Email Service > Email Sending](https://dash.cloudflare.com/?to=/:account/email-service/sending) — onboarding sets up SPF/DKIM/DMARC for you."
      },
      "DB": {
        "description": "D1 database for app data. Created automatically — the deploy command applies migrations on every deploy, and starter templates seed themselves on first request."
      },
      "R2_STORAGE_BUCKET": {
        "description": "R2 bucket for generated media (images, video, audio). Created automatically."
      },
      "R2_PUBLIC_ASSETS_BUCKET": {
        "description": "R2 bucket for public marketing/template assets. Created automatically."
      }
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}

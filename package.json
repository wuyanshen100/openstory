{
  "name": "openstory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "imports": {
    "#env": {
      "workerd": "./src/lib/env/cloudflare.ts",
      "default": "./src/lib/env/default.ts"
    },
    "#db-client": {
      "workerd": "./src/lib/db/client-d1.ts",
      "storybook": "./src/lib/db/client-stub.ts",
      "default": "./src/lib/db/client-node.ts"
    },
    "#storage": {
      "workerd": "./src/lib/storage/storage-cloudflare.ts",
      "default": "./src/lib/storage/storage-stub.ts"
    },
    "#flush-scheduler": {
      "workerd": "./src/lib/observability/flush-scheduler.cloudflare.ts",
      "default": "./src/lib/observability/flush-scheduler.ts"
    },
    "#actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    }
  },
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "setup:prd": "bun scripts/setup.ts --prod",
    "setup:deploy": "bun scripts/setup.ts --deploy",
    "setup:stg": "bun scripts/setup.ts --pr-preview",
    "r2:cors": "bun scripts/set-r2-cors.ts",
    "r2:cors:prd": "bun scripts/set-r2-cors.ts --env=prd",
    "r2:cors:stg": "bun scripts/set-r2-cors.ts --env=stg",
    "r2:cors:dev": "bun scripts/set-r2-cors.ts --env=dev",
    "setup:previews": "bun scripts/generate-style-previews.ts && bun scripts/upload-style-previews-to-r2.ts",
    "setup:system-previews": "bun scripts/generate-system-previews.ts && bun scripts/upload-system-previews-to-r2.ts",
    "styles:sample-videos": "bun scripts/generate-style-sample-videos.ts",
    "styles:sample-videos:upload": "bun scripts/upload-style-sample-videos-to-r2.ts",
    "styles:sample-videos:seed:local": "bun scripts/seed-style-sample-videos.ts --local",
    "styles:sample-videos:seed:d1": "bun scripts/seed-style-sample-videos.ts --d1",
    "styles:sample-videos:seed:sql": "bun scripts/seed-style-sample-videos.ts --sql",
    "upload:prompts": "bun scripts/upload-all-prompts.ts",
    "agent-harness": "bunx github:tombeckenham/agent-harness",
    "dev": "bun scripts/ensure-env.ts && bun run dev:app",
    "dev:all": "bun scripts/ensure-env.ts && CLOUDFLARE_INCLUDE_PROCESS_ENV=true VIDEO_EXPORT_DEV_URL=http://localhost:8080 bun run --parallel dev:app stripe:dev dev:bunny",
    "dev:app": "bun --sequential db:migrate:local db:seed:local dev:vite",
    "dev:vite": "bun scripts/build-content-collections.ts && vite dev",
    "dev:bunny": "cd containers/video-export && bun install && bun run dev",
    "stripe:dev": "source .env.local 2>/dev/null; [ -z \"${STRIPE_SECRET_KEY}\" ] && echo 'Skipping Stripe (no STRIPE_SECRET_KEY)' && exit 0; stripe listen --forward-to localhost:3000/api/billing/webhook --api-key=${STRIPE_SECRET_KEY}",
    "build": "vite build",
    "build:e2e": "CLOUDFLARE_ENV=test VITE_APP_URL=http://localhost:3001 VITE_DISABLE_DEVTOOLS=true vite build",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "dead-code": "bun knip",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "bun playwright test",
    "test:e2e:ui": "bun playwright test --ui",
    "test:e2e:full": "PLAYWRIGHT_FULL_PIPELINE=true bun playwright test full-sequence",
    "test:e2e:full:built": "PLAYWRIGHT_FULL_PIPELINE=true bun run build:e2e && bun run prepare:e2e-built && E2E_BUILT=true PLAYWRIGHT_FULL_PIPELINE=true bun playwright test full-sequence",
    "test:e2e:record": "E2E_RECORD=1 bun playwright test",
    "test:e2e:full:record": "E2E_RECORD=1 PLAYWRIGHT_FULL_PIPELINE=true bun playwright test full-sequence",
    "prepare:e2e-built": "mkdir -p .wrangler/deploy && printf '%s' '{\"configPath\":\"../../dist/server/wrangler.json\",\"auxiliaryWorkers\":[]}' > .wrangler/deploy/config.json",
    "test:e2e:setup": "bun run db:migrate:test && bun scripts/seed.ts --test",
    "db:generate": "bun drizzle-kit generate --config=drizzle.config.d1.ts",
    "db:migrate:local": "bun scripts/migrate-local-d1.ts",
    "db:migrate:test": "bun scripts/migrate-local-d1.ts --test",
    "db:migrate:prd": "bun scripts/flatten-migrations.ts && wrangler d1 migrations apply DB --env=production --remote",
    "explorer": "open http://localhost:3000/cdn-cgi/explorer/",
    "db:studio:local": "bun drizzle-kit studio --config=drizzle.config.local.ts",
    "db:studio:d1": "bun drizzle-kit studio --config=drizzle.config.d1.ts",
    "db:seed:local": "bun scripts/seed.ts --local",
    "db:fork:local": "bun scripts/db-worktree.ts --fork",
    "db:promote:local": "bun scripts/db-worktree.ts --promote",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "motion:codegen": "bun scripts/pull-motion-schemas.ts",
    "models:check": "bun scripts/check-model-updates.ts",
    "cf:typegen": "wrangler types",
    "cf:dev": "wrangler dev",
    "cf:deploy:prd": "bun run cf:typegen && CLOUDFLARE_ENV=production bun run build && bun run db:migrate:prd && wrangler deploy --env=production",
    "deploy": "bun scripts/flatten-migrations.ts && wrangler d1 migrations apply DB --remote && wrangler deploy",
    "deploy:production": "bun scripts/flatten-migrations.ts && wrangler d1 migrations apply DB --env=production --remote && wrangler deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@better-auth/api-key": "1.6.14",
    "@better-auth/passkey": "1.6.14",
    "@cloudflare/containers": "^0.3.7",
    "@content-collections/core": "0.15.0",
    "@content-collections/vite": "0.3.0",
    "@fal-ai/client": "^1.10.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@langfuse/client": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@libsql/client": "^0.17.3",
    "@logtape/logtape": "^2.1.1",
    "@logtape/redaction": "^2.1.1",
    "@openrouter/sdk": "0.13.20",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@posthog/react": "^1.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-email/components": "^1.0.12",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/ai": "^0.39.1",
    "@tanstack/ai-event-client": "^0.6.8",
    "@tanstack/ai-fal": "^0.9.9",
    "@tanstack/ai-openrouter": "^0.15.7",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-ssr-query": "^1.166.12",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/react-virtual": "^3.13.24",
    "@tanstack/zod-adapter": "^1.166.9",
    "@tiptap/extension-mention": "^3.23.6",
    "@tiptap/extensions": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/suggestion": "^3.23.6",
    "@unpic/react": "^1.0.2",
    "@videojs/react": "^10.0.0-beta.23",
    "better-auth": "1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^9.0.0",
    "drizzle-kit": "^1.0.0-rc.2-e38a2ba",
    "drizzle-orm": "^1.0.0-rc.2-e38a2ba",
    "gray-matter": "^4.0.3",
    "html-react-parser": "^6.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.16.0",
    "mediabunny": "^1.45.2",
    "mermaid": "^11.15.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.14",
    "posthog-js": "^1.373.4",
    "posthog-node": "^5.34.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
